# hive-gemini — Google Gemini CLI in a Podman sandbox
FROM hive-base

LABEL org.opencontainers.image.source="https://github.com/MartyFox/hive" \
      org.opencontainers.image.licenses="Apache-2.0" \
      org.opencontainers.image.description="Hive Google Gemini agent image"

RUN npm install -g @google/gemini-cli@0.41.2

USER agent

ENTRYPOINT ["hive-agent-entrypoint", "gemini", "gemini"]
