# hive-claude — Claude Code CLI in a Podman sandbox
FROM hive-base

LABEL org.opencontainers.image.source="https://github.com/MartyFox/hive" \
      org.opencontainers.image.licenses="Apache-2.0" \
      org.opencontainers.image.description="Hive Claude Code agent image"

RUN npm install -g @anthropic-ai/claude-code@2.1.140

USER agent

ENTRYPOINT ["claude", "--dangerously-skip-permissions"]
