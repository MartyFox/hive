# hive-base — shared foundation for all hive agent images
# node:22-bookworm-slim provides Node LTS + npm on Debian 12
FROM node:22-bookworm-slim

# ── System tools ─────────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    wget \
    jq \
    ripgrep \
    zsh \
    bash \
    ca-certificates \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# ── Beads CLI (bd) ────────────────────────────────────────────────────────────
RUN curl -fsSL https://raw.githubusercontent.com/gastownhall/beads/main/scripts/install.sh | bash \
    || echo "[hive-base] bd install skipped (not available yet)"

# ── Non-root agent user ───────────────────────────────────────────────────────
# node:22-bookworm-slim ships a 'node' user at uid/gid 1000 — rename it.
RUN groupmod -n agent node \
    && usermod -l agent -d /home/agent -m -s /bin/zsh node \
    && mkdir -p /workspace \
    && chown agent:agent /workspace

WORKDIR /workspace
