# hive-base — shared foundation for all hive agent images
# node:22-bookworm-slim provides Node LTS + npm on Debian 12
FROM node:22-bookworm-slim

# ── ca-certificates must be installed before update-ca-certificates is called ─
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# ── Corporate CA injection ─────────────────────────────────────────
# Optional cert: if build context contains extra-ca.pem (non-empty), install it.
# No cert file means non-corporate environment; skip cert setup entirely.
RUN --mount=type=bind,source=.,target=/context,ro \
    if [ -s /context/extra-ca.pem ]; then \
      mkdir -p /usr/local/share/ca-certificates && \
      cp /context/extra-ca.pem /usr/local/share/ca-certificates/extra-ca.crt && \
      update-ca-certificates; \
    fi

# ── System tools ─────────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    wget \
    jq \
    ripgrep \
    zsh \
    bash \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# ── GitHub CLI (gh) ─────────────────────────────────────────────────────────
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update \
    && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# ── Beads CLI (bd) — optional, default off ───────────────────────────────────
# Opt-in: set HIVE_BEADS=1 in ~/.hive/config or pass --build-arg HIVE_BEADS=1
# when calling hive build.  Default is 0 (not installed).
ARG HIVE_BEADS=0
RUN if [ "$HIVE_BEADS" = "1" ]; then \
      curl -fsSL https://raw.githubusercontent.com/gastownhall/beads/main/scripts/install.sh | bash; \
    else \
      echo "[hive-base] Beads (bd) not installed — set HIVE_BEADS=1 in ~/.hive/config to include"; \
    fi

# ── Non-root agent user ───────────────────────────────────────────────────────
# node:22-bookworm-slim ships a 'node' user at uid/gid 1000 — rename it.
RUN groupmod -n agent node \
    && usermod -l agent -d /home/agent -m -s /bin/zsh node \
    && mkdir -p /workspace \
    && chown agent:agent /workspace

WORKDIR /workspace
